rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.owner_id;
    }
    function uidUnchanged() {
      return !('owner_id' in request.resource.data) || request.resource.data.owner_id == request.auth.uid;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidParentTask(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.deadline is string &&
             data.planned_hours is number &&
             data.owner_id == request.auth.uid;
    }

    function isValidSubTask(data) {
      return data.task_name is string && data.task_name.size() > 0 &&
             data.parent_task_id is string &&
             data.owner_id == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /parent_tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidParentTask(request.resource.data);
      allow update: if isDocOwner() && isValidParentTask(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /sub_tasks/{subTaskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSubTask(request.resource.data);
      allow update: if isDocOwner() && isValidSubTask(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /task_templates/{templateId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.owner_id == request.auth.uid;
      allow delete: if isDocOwner();
    }

    match /template_items/{itemId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.owner_id == request.auth.uid;
      allow delete: if isDocOwner();
    }

    match /settings/{settingId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.owner_id == request.auth.uid;
      allow delete: if isDocOwner();
    }
  }
}
