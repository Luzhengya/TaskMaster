rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.owner_id;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "zhengya2021@gmail.com" && request.auth.token.email_verified == true));
    }
    function uidUnchanged() {
      return !('owner_id' in request.resource.data) || request.resource.data.owner_id == request.auth.uid;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidParentTask(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.deadline is string &&
             data.planned_hours is number &&
             data.owner_id == request.auth.uid &&
             (!('is_hidden' in data) || data.is_hidden is bool) &&
             (!('order' in data) || data.order is number) &&
             (!('due_date' in data) || data.due_date is string) &&
             (!('actual_hours' in data) || data.actual_hours is number) &&
             (!('progress' in data) || data.progress is number) &&
             hasOnlyAllowedFields(['name', 'deadline', 'due_date', 'planned_hours', 'actual_hours', 'progress', 'is_hidden', 'order', 'owner_id', 'created_at', 'updated_at']);
    }

    function isValidSubTask(data) {
      return data.task_name is string && data.task_name.size() <= 1000 &&
             data.parent_task_id is string &&
             data.owner_id == request.auth.uid &&
             (data.status in ['遅れ', '済', '進行中', '未着手', '保留', '着手遅れ', '期限遅れ']) &&
             (data.priority in ['A', 'B', 'C']) &&
             data.planned_hours is number &&
             data.actual_hours is number &&
             (!('system' in data) || data.system is string) &&
             (!('month' in data) || data.month is string) &&
             (!('daily_report_date' in data) || data.daily_report_date is string) &&
             (!('start_date' in data) || data.start_date is string) &&
             (!('due_date' in data) || data.due_date is string) &&
             (!('final_deadline' in data) || data.final_deadline is string) &&
             (!('remarks' in data) || data.remarks is string) &&
             (!('is_in_report' in data) || data.is_in_report is bool) &&
             (!('order' in data) || data.order is number) &&
             (!('weekday' in data) || data.weekday is string) &&
             (!('week' in data) || data.week is string) &&
             (!('week_number' in data) || data.week_number is number) &&
             (!('flag' in data) || data.flag is number) &&
             (!('icon_data' in data) || data.icon_data is string) &&
             (!('delay_reason' in data) || data.delay_reason is string) &&
             (!('impact_assessment' in data) || data.impact_assessment in ['小', '中', '大']) &&
             hasOnlyAllowedFields([
               'parent_task_id', 'system', 'month', 'daily_report_date',
               'start_date', 'due_date', 'final_deadline', 'status',
               'task_name', 'planned_hours', 'actual_hours', 'priority',
               'remarks', 'delay_reason', 'impact_assessment', 'is_in_report',
               'order', 'weekday', 'week', 'week_number', 'flag', 'icon_data',
               'owner_id', 'created_at', 'updated_at'
             ]);
    }

    function isValidTaskTemplate(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.owner_id == request.auth.uid &&
             (!('order' in data) || data.order is number) &&
             hasOnlyAllowedFields(['name', 'order', 'owner_id', 'created_at', 'updated_at']);
    }

    function isValidTemplateItem(data) {
      return data.task_name is string && data.task_name.size() <= 1000 &&
             data.template_id is string &&
             data.owner_id == request.auth.uid &&
             (data.status in ['遅れ', '済', '進行中', '未着手', '保留', '着手遅れ', '期限遅れ']) &&
             (data.priority in ['A', 'B', 'C']) &&
             data.planned_hours is number &&
             (!('system' in data) || data.system is string) &&
             (!('remarks' in data) || data.remarks is string) &&
             (!('order' in data) || data.order is number) &&
             hasOnlyAllowedFields(['template_id', 'system', 'task_name', 'status', 'planned_hours', 'priority', 'remarks', 'order', 'owner_id', 'created_at', 'updated_at']);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
    }

    match /parent_tasks/{taskId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if (isAuthenticated() && isValidParentTask(request.resource.data)) || isAdmin();
      allow update: if (isDocOwner() || isAdmin()) && isValidParentTask(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /sub_tasks/{subTaskId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if (isAuthenticated() && isValidSubTask(request.resource.data)) || isAdmin();
      allow update: if (isDocOwner() || isAdmin()) && isValidSubTask(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /task_templates/{templateId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if (isAuthenticated() && isValidTaskTemplate(request.resource.data)) || isAdmin();
      allow update: if (isDocOwner() || isAdmin()) && isValidTaskTemplate(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /template_items/{itemId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if (isAuthenticated() && isValidTemplateItem(request.resource.data)) || isAdmin();
      allow update: if (isDocOwner() || isAdmin()) && isValidTemplateItem(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
      allow update: if (isDocOwner() || isAdmin()) && request.resource.data.owner_id == request.auth.uid;
      allow delete: if isDocOwner() || isAdmin();
    }

    match /daily_reports/{reportId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
      allow update: if (isDocOwner() || isAdmin()) && request.resource.data.owner_id == request.auth.uid;
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
