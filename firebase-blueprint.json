{
  "entities": {
    "parent_tasks": {
      "title": "Parent Task",
      "description": "Main project or case containing sub-tasks",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Case name" },
        "deadline": { "type": "string", "format": "date", "description": "Main deadline (Honban-bi)" },
        "due_date": { "type": "string", "format": "date" },
        "planned_hours": { "type": "number", "description": "Total planned hours" },
        "actual_hours": { "type": "number" },
        "progress": { "type": "number" },
        "is_hidden": { "type": "boolean" },
        "order": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "owner_id": { "type": "string", "description": "User ID of the owner" }
      },
      "required": ["name", "deadline", "planned_hours", "owner_id"]
    },
    "sub_tasks": {
      "title": "Sub Task",
      "description": "Individual task item within a parent task",
      "type": "object",
      "properties": {
        "parent_task_id": { "type": "string", "description": "Reference to parent task" },
        "system": { "type": "string" },
        "month": { "type": "string" },
        "daily_report_date": { "type": "string", "format": "date" },
        "start_date": { "type": "string", "format": "date" },
        "due_date": { "type": "string", "format": "date" },
        "final_deadline": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["遅れ", "済", "進行中", "未着手", "保留", "着手遅れ", "期限遅れ", "着着手遅れ"] },
        "task_name": { "type": "string" },
        "planned_hours": { "type": "number" },
        "actual_hours": { "type": "number" },
        "priority": { "type": "string", "enum": ["A", "B", "C"] },
        "remarks": { "type": "string" },
        "is_in_report": { "type": "boolean" },
        "order": { "type": "integer" },
        "weekday": { "type": "string" },
        "week": { "type": "string" },
        "week_number": { "type": "integer" },
        "flag": { "type": "integer" },
        "owner_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["parent_task_id", "task_name", "owner_id"]
    },
    "task_templates": {
      "title": "Task Template",
      "description": "Reusable set of sub-tasks",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "order": { "type": "integer" },
        "owner_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "owner_id"]
    },
    "template_items": {
      "title": "Template Item",
      "description": "Individual task within a template",
      "type": "object",
      "properties": {
        "template_id": { "type": "string" },
        "system": { "type": "string" },
        "task_name": { "type": "string" },
        "status": { "type": "string" },
        "planned_hours": { "type": "number" },
        "priority": { "type": "string" },
        "remarks": { "type": "string" },
        "order": { "type": "integer" },
        "owner_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["template_id", "task_name", "owner_id"]
    },
    "settings": {
      "title": "System Settings",
      "description": "User preferences and AI config",
      "type": "object",
      "properties": {
        "owner_id": { "type": "string" },
        "ai_models": { "type": "string", "description": "JSON string of AI config" },
        "ui_preferences": { "type": "string", "description": "JSON string of UI preferences" },
        "notification_rules": { "type": "string", "description": "JSON string of notification rules" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["owner_id"]
    }
  },
  "firestore": {
    "/parent_tasks/{taskId}": { "schema": "parent_tasks", "description": "Main tasks" },
    "/sub_tasks/{subTaskId}": { "schema": "sub_tasks", "description": "Sub tasks" },
    "/task_templates/{templateId}": { "schema": "task_templates", "description": "Templates" },
    "/template_items/{itemId}": { "schema": "template_items", "description": "Template details" },
    "/settings/{settingId}": { "schema": "settings", "description": "User settings" }
  }
}
